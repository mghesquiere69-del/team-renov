---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Terrasses & allées",
  "Abords de piscine",
  "Dalles & pavés",
  "Antidérapant",
];

const relatedServices = [
  { title: "Maçonnerie", href: "/services/maconnerie" },
  { title: "Carrelage intérieur", href: "/services/carrelage" },
  { title: "Enduit projeté", href: "/services/enduit-projete" },
  { title: "Drain français", href: "/services/drain-francais" },
];
---

<ServicePageLayout
  title="Carrelage extérieur"
  metaTitle="Carrelage Extérieur – Team Renov | Terrasses, Allées & Piscines"
  metaDescription="Pose de carrelage extérieur, dalles et pavés pour terrasses, allées et abords de piscine. Devis gratuit en 48h."
  category="Travaux Extérieurs"
  categoryHref="/services#exterieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6z"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <Section title="Sublimez vos espaces extérieurs" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10" data-animate>
      <div class="space-y-4">
        <p class="text-gray-medium leading-relaxed">
          Le carrelage extérieur apporte esthétique et durabilité à vos terrasses, allées
          de jardin et abords de piscine. Nos carreleurs sélectionnent des matériaux
          résistants au gel, aux UV et aux chocs thermiques.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Nous posons du grès cérame extérieur, des dalles sur plots, des pavés et de la
          pierre naturelle avec une attention particulière aux pentes d'évacuation des eaux
          et aux propriétés antidérapantes des revêtements choisis.
        </p>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm">
        Photo terrasse carrelée
      </div>
    </div>
  </Section>

  <Section title="Nos prestations" bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        { title: "Terrasses", desc: "Pose de carrelage ou dalles sur chape ou sur plots pour terrasses de plain-pied ou surélevées." },
        { title: "Allées & chemins", desc: "Pavage et dallage d'allées de jardin, entrées de garage et chemins piétons." },
        { title: "Abords de piscine", desc: "Revêtements antidérapants, margelles et plages de piscine en carrelage ou pierre." },
        { title: "Escaliers extérieurs", desc: "Habillage d'escaliers en carrelage extérieur résistant et antidérapant." },
        { title: "Dalles sur plots", desc: "Pose de dalles sur plots réglables pour terrasses ventilées sans chape." },
        { title: "Joints & étanchéité", desc: "Joints résistants aux intempéries et traitement hydrofuge des surfaces." },
      ].map((item) => (
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>
</ServicePageLayout>
