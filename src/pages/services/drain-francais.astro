---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Protection des fondations",
  "Drainage périphérique",
  "Étanchéité sous-sol",
  "Pompe de relevage",
];

const relatedServices = [
  { title: "Maçonnerie", href: "/services/maconnerie" },
  { title: "Enduit projeté", href: "/services/enduit-projete" },
  { title: "Carrelage extérieur", href: "/services/carrelage-exterieur" },
  { title: "Clé en main", href: "/services/cle-en-main" },
];
---

<ServicePageLayout
  title="Drain français"
  metaTitle="Drain Français – Team Renov | Protection contre l'Humidité"
  metaDescription="Installation de drains français pour protéger vos fondations et sous-sols contre l'humidité. Devis gratuit en 48h."
  category="Travaux Extérieurs"
  categoryHref="/services#exterieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <Section title="Protégez votre maison de l'humidité" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10" data-animate>
      <div class="space-y-4">
        <p class="text-gray-medium leading-relaxed">
          Le drain français est une solution efficace et éprouvée pour évacuer les eaux
          souterraines loin de vos fondations. Il prévient les infiltrations, l'humidité
          dans les murs et les dégâts structurels liés à l'eau.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Nos équipes réalisent le terrassement périphérique, la pose du géotextile et du
          drain, le remblaiement avec du gravier drainant et, si nécessaire, l'installation
          d'une pompe de relevage. Une solution durable pour un sous-sol sain.
        </p>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm">
        Photo installation drain
      </div>
    </div>
  </Section>

  <Section title="Nos prestations drainage" bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        { title: "Diagnostic humidité", desc: "Analyse de la source d'humidité et recommandation de la solution de drainage adaptée." },
        { title: "Drain périphérique", desc: "Tranchée d'assainissement autour des fondations avec tuyau perforé et gravier." },
        { title: "Étanchéité fondations", desc: "Application d'un enduit d'étanchéité et pose de membrane sur les murs enterrés." },
        { title: "Pompe de relevage", desc: "Installation de pompe pour évacuer les eaux vers le réseau en cas de terrain bas." },
        { title: "Cuvelage", desc: "Traitement intérieur des sous-sols avec enduit et résine hydrofuge." },
        { title: "Regard de visite", desc: "Pose de regards pour faciliter l'entretien et le contrôle du réseau de drainage." },
      ].map((item) => (
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>
</ServicePageLayout>
