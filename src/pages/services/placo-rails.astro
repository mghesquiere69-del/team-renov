---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Cloisons & faux plafonds sur mesure",
  "Isolation thermique et acoustique",
  "Matériaux certifiés (Placo, Knauf, Siniat)",
  "Finitions prêtes à peindre",
];

const relatedServices = [
  { title: "Enduit", href: "/services/enduit" },
  { title: "Peinture", href: "/services/peinture" },
  { title: "Électricité", href: "/services/electricite" },
  { title: "Menuiserie", href: "/services/menuiserie" },
  { title: "Rénovation complète", href: "/services/renovation-complete" },
];
---

<ServicePageLayout
  title="Installation de Placo & Rails – Cloisons et Faux Plafonds"
  metaTitle="Placo & Rails – Team Renov | Cloisons, Faux Plafonds & Isolation"
  metaDescription="Pose de placo, rails métalliques, cloisons de séparation, faux plafonds et isolation thermique et acoustique. Artisans plaquistes qualifiés. Devis gratuit."
  category="Travaux Intérieurs"
  categoryHref="/services#interieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <!-- Section 1 : Intro + Slider Avant/Après -->
  <Section title="Des plaquistes experts pour transformer votre intérieur" bg="white">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center" data-animate>
      <div class="space-y-5">
        <p class="text-gray-medium leading-relaxed">
          Vous voulez <strong class="text-gray-dark">créer une chambre supplémentaire</strong>,
          aménager vos combles ou simplement redistribuer l'espace de votre appartement ?
          Le placo est la solution la plus rapide et la plus efficace pour repenser votre intérieur
          sans toucher à la structure porteuse de votre bâtiment.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Chez <strong class="text-gray-dark">Team Renov</strong>, nos plaquistes interviennent de A à Z :
          prise de cotes, montage de l'ossature métallique (rails et montants),
          pose des plaques BA13, isolation et traitement des joints.
          Résultat : des surfaces parfaitement lisses, prêtes à peindre.
        </p>
        <ul class="space-y-2 text-sm text-gray-medium">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Matériaux certifiés : Placo®, Knauf, Siniat
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Travaux conformes aux DTU en vigueur
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Devis gratuit et détaillé sous 48 h
          </li>
        </ul>
      </div>

      <!-- Slider Avant / Après -->
      <div class="ba-slider">
        <div class="ba-slider__container">
          <img
            src="/images/services/placo-rails-apres.jpg"
            alt="Pièce terminée après pose de placo, cloisons et faux plafonds"
            class="ba-slider__img ba-slider__img--after"
          />
          <div class="ba-slider__overlay">
            <img
              src="/images/services/placo-rails-avant.jpg"
              alt="Pièce brute avant pose du placo : murs non isolés"
              class="ba-slider__img ba-slider__img--before"
            />
          </div>
          <input type="range" min="0" max="100" value="50" class="ba-slider__range" aria-label="Comparer avant et après" />
          <div class="ba-slider__handle">
            <div class="ba-slider__handle-line"></div>
            <div class="ba-slider__handle-circle">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9"/></svg>
            </div>
            <div class="ba-slider__handle-line"></div>
          </div>
          <span class="ba-slider__label ba-slider__label--before">Avant</span>
          <span class="ba-slider__label ba-slider__label--after">Après</span>
        </div>
      </div>
    </div>
  </Section>

  <!-- Section 2 : Prestations détaillées -->
  <Section title="Ce qu'on fait concrètement" subtitle="Chaque prestation est réalisée dans les règles de l'art, avec des matériaux de qualité professionnelle." bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        {
          title: "Cloisons de séparation",
          desc: "Créez de nouvelles pièces sans gros travaux. Nos cloisons en plaque de plâtre sur ossature métallique sont montées proprement, avec passage de gaines électriques intégré si nécessaire.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5M13.5 6.75H15m-1.5 3H15m-1.5 3H15"/></svg>`
        },
        {
          title: "Faux plafonds",
          desc: "Plafonds suspendus en BA13 ou dalles : masquez les gaines techniques, intégrez des spots LED encastrés et gagnez en esthétique. Idéal aussi pour corriger une hauteur sous plafond.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/></svg>`
        },
        {
          title: "Isolation thermique (ITI)",
          desc: "Doublage des murs avec laine de verre, laine de roche ou polystyrène expansé. Réduisez vos factures de chauffage et améliorez votre classement DPE — un vrai plus pour la revente.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/></svg>`
        },
        {
          title: "Isolation acoustique",
          desc: "Voisins bruyants, chambres mal insonorisées ? Nous posons des systèmes phoniques performants entre pièces de vie, logements mitoyens ou en sous-face de planchers.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z"/></svg>`
        },
        {
          title: "Habillage & coffrages",
          desc: "Poutres disgracieuses, tuyauteries apparentes, gaines VMC ? Nous les habillons proprement en placo pour un rendu net et moderne, sans perdre l'accès aux réseaux techniques.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`
        },
        {
          title: "Joints & finitions",
          desc: "Bandes, enduit, ponçage minutieux : on ne laisse rien au hasard. Nos surfaces sont livrées parfaitement lisses, prêtes pour la peinture, le papier peint ou l'enduit décoratif.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`
        },
      ].map((item) => (
        <div class="card">
          <div class="w-10 h-10 bg-accent/10 text-accent rounded-lg flex items-center justify-center mb-3">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Section 3 : Types de projets -->
  <Section title="Quel que soit votre projet, on s'adapte" bg="white">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8" data-animate>
      {[
        {
          title: "Aménagement de combles",
          desc: "Transformez un grenier inutilisé en espace de vie : isolation sous rampants, cloisons, fenêtres de toit et finitions complètes. Un investissement rentable qui ajoute des mètres carrés à votre logement.",
        },
        {
          title: "Redistribution d'un appartement",
          desc: "Abattez une cloison pour ouvrir la cuisine sur le salon, créez un dressing ou ajoutez une salle d'eau. Nous coordonnons placo, électricité et plomberie pour un résultat clé en main.",
        },
        {
          title: "Rénovation après dégâts",
          desc: "Dégât des eaux, fissures, moisissures ? Nous déposons les plaques endommagées, traitons le support et remettons à neuf vos murs et plafonds pour un intérieur sain et propre.",
        },
        {
          title: "Locaux professionnels",
          desc: "Bureaux, cabinets, commerces : cloisonnement, isolation phonique renforcée et faux plafonds acoustiques. Nous intervenons aussi en milieu occupé, avec un planning adapté à votre activité.",
        },
      ].map((item) => (
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-primary/10 text-primary rounded-lg flex items-center justify-center shrink-0 mt-1">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          </div>
          <div>
            <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
            <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Section 4 : Méthode de travail -->
  <Section title="Comment se déroule votre chantier ?" subtitle="Un processus clair, étape par étape, pour que vous sachiez exactement à quoi vous attendre." bg="light">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6" data-animate>
      {[
        { step: "01", title: "Visite & devis", desc: "On se déplace chez vous, on prend les mesures et on établit un devis détaillé gratuit sous 48 h. Pas de surprises." },
        { step: "02", title: "Préparation", desc: "Protection de vos sols et meubles, traçage au sol et au laser, livraison et stockage des matériaux sur place." },
        { step: "03", title: "Pose & isolation", desc: "Montage des rails et montants, insertion de l'isolant, vissage des plaques de plâtre. Tout est fait selon les DTU." },
        { step: "04", title: "Finitions", desc: "Bandes à joints, enduit, ponçage minutieux. On livre des murs parfaitement lisses et on nettoie le chantier." },
      ].map((item) => (
        <div class="text-center">
          <div class="w-12 h-12 bg-accent text-white rounded-xl flex items-center justify-center mx-auto mb-3 text-lg font-bold">
            {item.step}
          </div>
          <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
          <p class="text-sm text-gray-medium">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Section 5 : Pourquoi nous -->
  <Section title="Pourquoi choisir Team Renov ?" bg="white">
    <div class="max-w-5xl mx-auto" data-animate>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {[
          { title: "Plaquistes expérimentés", desc: "Plus de 10 ans de métier. Nos artisans sont formés aux techniques modernes et aux dernières normes." },
          { title: "Matériaux de marque", desc: "Uniquement des produits certifiés — Placo®, Knauf, Siniat — pour une résistance et une durabilité maximales." },
          { title: "Respect des délais", desc: "Un planning est fixé dès le devis. On s'y tient. Vous savez quand ça commence et quand ça finit." },
          { title: "Chantier propre", desc: "Bâchage, aspiration quotidienne, tri des déchets. On respecte votre logement comme si c'était le nôtre." },
          { title: "Coordination multi-corps", desc: "Électricité, plomberie, peinture : on gère tout en interne pour éviter les allers-retours entre artisans." },
          { title: "Devis transparent", desc: "Chaque ligne est détaillée : matériaux, main-d'œuvre, finitions. Pas de mauvaise surprise à la fin du chantier." },
        ].map((item) => (
          <div class="card">
            <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
            <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center">
        <p class="text-lg text-gray-dark font-medium mb-4">
          Prêt à transformer votre intérieur ?
        </p>
        <a href="/contact" class="btn-primary">Demander un devis gratuit</a>
      </div>
    </div>
  </Section>
</ServicePageLayout>

<style>
  /* --- Before/After Slider --- */
  .ba-slider__container {
    position: relative;
    overflow: hidden;
    border-radius: 1rem;
    aspect-ratio: 4 / 3;
    user-select: none;
    -webkit-user-select: none;
  }

  .ba-slider__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-slider__img--after {
    position: absolute;
    inset: 0;
  }

  .ba-slider__overlay {
    position: absolute;
    inset: 0;
    clip-path: inset(0 50% 0 0);
    z-index: 1;
  }

  .ba-slider__img--before {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ba-slider__range {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: ew-resize;
    z-index: 3;
  }

  .ba-slider__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
    pointer-events: none;
  }

  .ba-slider__handle-line {
    flex: 1;
    width: 3px;
    background: white;
    box-shadow: 0 0 6px rgba(0,0,0,.3);
  }

  .ba-slider__handle-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,.25);
    flex-shrink: 0;
  }

  .ba-slider__label {
    position: absolute;
    bottom: 0.75rem;
    z-index: 2;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: white;
    background: rgba(0,0,0,.5);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    pointer-events: none;
  }

  .ba-slider__label--before {
    left: 0.75rem;
  }

  .ba-slider__label--after {
    right: 0.75rem;
  }
</style>

<script>
  document.querySelectorAll('.ba-slider__range').forEach((range) => {
    const container = range.closest('.ba-slider__container');
    if (!container) return;
    const overlay = container.querySelector('.ba-slider__overlay') as HTMLElement;
    const handle = container.querySelector('.ba-slider__handle') as HTMLElement;

    function update(value: number) {
      const pct = value + '%';
      overlay.style.clipPath = 'inset(0 ' + (100 - value) + '% 0 0)';
      handle.style.left = pct;
    }

    range.addEventListener('input', (e) => {
      update(Number((e.target as HTMLInputElement).value));
    });
  });
</script>
