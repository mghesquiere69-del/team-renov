---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Cloisons & séparations",
  "Faux plafonds",
  "Isolation thermique & phonique",
  "Finitions soignées",
];

const relatedServices = [
  { title: "Enduit", href: "/services/enduit" },
  { title: "Peinture", href: "/services/peinture" },
  { title: "Électricité", href: "/services/electricite" },
  { title: "Rénovation complète", href: "/services/renovation-complete" },
];
---

<ServicePageLayout
  title="Placo & Rails"
  metaTitle="Placo & Rails – Team Renov | Cloisons, Faux Plafonds & Isolation"
  metaDescription="Pose de plaques de plâtre, création de cloisons, faux plafonds et isolation intérieure. Artisans qualifiés, devis gratuit en 48h."
  category="Travaux Intérieurs"
  categoryHref="/services#interieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25a2.25 2.25 0 01-2.25-2.25v-2.25z"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <Section title="Un aménagement sur mesure" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10" data-animate>
      <div class="space-y-4">
        <p class="text-gray-medium leading-relaxed">
          La pose de placo et de rails est la base de tout aménagement intérieur réussi.
          Que vous souhaitiez créer de nouvelles pièces, isoler votre logement ou habiller
          vos murs et plafonds, nos plaquistes interviennent avec précision et savoir-faire.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Nous utilisons exclusivement des matériaux de qualité (Placo®, Knauf, Siniat) et
          respectons les DTU en vigueur pour vous garantir un résultat durable, conforme aux
          normes thermiques et acoustiques.
        </p>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm">
        Photo chantier placo
      </div>
    </div>
  </Section>

  <Section title="Nos prestations placo" bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        { title: "Cloisons de distribution", desc: "Création de pièces, séparations légères et cloisons de doublage pour redistribuer vos espaces." },
        { title: "Faux plafonds", desc: "Plafonds suspendus en plaques de plâtre pour masquer les gaines et améliorer l'esthétique." },
        { title: "Isolation thermique", desc: "Doublage avec laine de verre, laine de roche ou polystyrène pour une meilleure performance énergétique." },
        { title: "Isolation phonique", desc: "Solutions acoustiques pour réduire les nuisances sonores entre pièces et avec l'extérieur." },
        { title: "Habillage de murs", desc: "Mise en place de plaques pour rattraper des murs irréguliers ou créer des niches décoratives." },
        { title: "Trappe de visite", desc: "Pose de trappes d'accès pour gaines techniques, plomberie et électricité." },
      ].map((item) => (
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section title="Notre méthode de travail" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-6" data-animate>
      {[
        { step: "01", title: "Visite technique", desc: "Prise de cotes, analyse des contraintes et recommandations techniques." },
        { step: "02", title: "Devis détaillé", desc: "Chiffrage précis poste par poste, envoyé sous 48h." },
        { step: "03", title: "Réalisation", desc: "Pose des rails, montage des plaques, traitement des joints." },
        { step: "04", title: "Finitions", desc: "Enduit, ponçage et nettoyage pour des surfaces prêtes à peindre." },
      ].map((item) => (
        <div class="text-center">
          <div class="w-12 h-12 bg-accent text-white rounded-xl flex items-center justify-center mx-auto mb-3 text-lg font-bold">
            {item.step}
          </div>
          <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
          <p class="text-sm text-gray-medium">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>
</ServicePageLayout>
