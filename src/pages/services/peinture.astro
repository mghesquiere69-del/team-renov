---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Finitions impeccables",
  "Peintures faible COV",
  "Devis gratuit sous 48h",
  "Tous supports intérieurs",
];

const relatedServices = [
  { title: "Enduit", href: "/services/enduit" },
  { title: "Placo & Rails", href: "/services/placo-rails" },
  { title: "Rénovation complète", href: "/services/renovation-complete" },
  { title: "Menuiserie", href: "/services/menuiserie" },
  { title: "Clé en main", href: "/services/cle-en-main" },
];
---

<ServicePageLayout
  title="Peinture intérieure"
  metaTitle="Peinture Intérieure – Team Renov | Île-de-France"
  metaDescription="Peintre en Île-de-France : murs, plafonds, boiseries, effets décoratifs. Préparation soignée, 2 couches minimum. Devis gratuit 48h."
  category="Travaux Intérieurs"
  categoryHref="/services#interieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <!-- SECTION 1 — Accroche : Problème → Agitation → Solution -->
  <Section title="Des murs défraîchis ? On leur redonne vie." bg="white">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center" data-animate>
      <div class="space-y-5">
        <p class="text-gray-medium leading-relaxed">
          Traces de meubles, jaunissement au plafond, peinture qui s'écaille autour des fenêtres…
          <strong class="text-gray-dark">Un intérieur mal peint vieillit un logement de 10 ans d'un seul coup d'œil.</strong>
          C'est souvent le premier détail que remarquent vos visiteurs — ou vos futurs acheteurs.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Chez <strong class="text-gray-dark">Team Renov</strong>, nos peintres ne se contentent pas de passer un rouleau.
          On prépare chaque surface avec rigueur — rebouchage des fissures, ponçage, sous-couche d'accrochage — puis on applique systématiquement <strong class="text-gray-dark">2 couches croisées minimum</strong> avec un temps de séchage respecté entre chaque passe.
          Résultat : une finition lisse, uniforme, durable.
        </p>
        <p class="text-gray-medium leading-relaxed">
          On intervient partout en Île-de-France, sur tous types de supports : plâtre, placo, bois, métal, béton.
          Que ce soit pour rafraîchir un studio ou peindre un appartement entier après rénovation, on s'adapte à votre planning et à votre budget.
        </p>
        <ul class="space-y-2 text-sm text-gray-medium">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Peintures Tollens, Sikkens, Zolpan — qualité professionnelle garantie
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Gamme éco-responsable à faible émission de COV disponible
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Protection complète de vos meubles et sols pendant le chantier
          </li>
        </ul>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm italic">
        Photo : peintre Team Renov appliquant une peinture blanche mate au rouleau sur un mur d'appartement rénové, bâches au sol, éclairage naturel
      </div>
    </div>
  </Section>

  <!-- SECTION 2 — Prestations détaillées -->
  <Section title="Nos prestations peinture" subtitle="Du mur brut à la touche finale décorative, chaque étape est réalisée dans les règles de l'art." bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        {
          title: "Peinture murs",
          desc: "Application au rouleau ou au pistolet airless sur murs neufs ou rénovés. Deux couches croisées minimum, avec un ponçage inter-couches pour un rendu parfaitement lisse. Finition mate, satinée ou velours selon vos préférences.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6z"/></svg>`
        },
        {
          title: "Peinture plafonds",
          desc: "Les plafonds révèlent la moindre imperfection. On traite les fissures, on applique un enduit de lissage si nécessaire, puis une peinture mate blanche spéciale plafond anti-traces de reprise.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/></svg>`
        },
        {
          title: "Boiseries & portes",
          desc: "Laquage de portes, plinthes, encadrements de fenêtres et menuiseries intérieures. Ponçage, sous-couche d'accrochage puis laque satinée ou brillante pour un rendu net et résistant aux chocs.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 11.25l-3-3m0 0l-3 3m3-3v7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
        },
        {
          title: "Effets décoratifs",
          desc: "Peinture à la chaux, badigeon, stucco vénitien, béton ciré mural, enduit taloché. Ces finitions haut de gamme apportent du caractère à vos pièces de vie. On réalise un échantillon sur place avant validation.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>`
        },
        {
          title: "Préparation des supports",
          desc: "C'est l'étape invisible qui fait toute la différence. Lessivage, rebouchage au Toupret, ponçage grain 120, application de sous-couche Tollens ou Zolpan adaptée au support. Sans cette préparation, aucune peinture ne tient.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1m0 0L3 12.75m3.32-2.68L12 3.75l2.25 2.25M17.58 8.83l5.1 5.1m0 0l-3.32 2.68m3.32-2.68L17.25 20.25l-2.25-2.25"/></svg>`
        },
        {
          title: "Ravalement & cages d'escalier",
          desc: "Parties communes d'immeubles, montées d'escalier, halls d'entrée. On intervient avec du matériel adapté (échafaudages, nacelles) et on coordonne les travaux pour limiter la gêne des résidents.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5M13.5 6.75H15m-1.5 3H15m-1.5 3H15"/></svg>`
        },
      ].map((item) => (
        <div class="card">
          <div class="w-10 h-10 bg-accent/10 text-accent rounded-lg flex items-center justify-center mb-3">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- SECTION 3 — Cas d'usage concrets -->
  <Section title="Vos projets peinture, nos solutions" bg="white">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8" data-animate>
      {[
        {
          title: "Rafraîchissement avant vente ou location",
          desc: "Un coup de peinture propre augmente la valeur perçue d'un logement et accélère la transaction. On intervient en 2 à 4 jours sur un T3, couleurs neutres et finitions impeccables. Idéal pour les investisseurs locatifs qui veulent remettre un bien sur le marché rapidement.",
        },
        {
          title: "Finitions après travaux de rénovation",
          desc: "Vous venez de faire poser du placo, de l'enduit ou de refaire l'électricité ? On prend le relais pour la dernière étape : bandes à joints masquées, surfaces uniformes, peinture finale. On coordonne directement avec nos équipes placo et enduit.",
        },
        {
          title: "Changement de déco et mise en couleur",
          desc: "Vous en avez assez du blanc partout ? On vous aide à choisir les bonnes teintes selon la luminosité de chaque pièce. Murs d'accent, soubassements bicolores, plafonds colorés : on maîtrise les techniques pour des résultats modernes et harmonieux.",
        },
        {
          title: "Remise en état après dégât des eaux",
          desc: "Auréoles, cloques, moisissures après un dégât des eaux ? On traite le support en profondeur avec un anti-moisissure, on laisse sécher, puis on repart sur une base saine. Le résultat est invisible — comme s'il ne s'était rien passé.",
        },
      ].map((item) => (
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-primary/10 text-primary rounded-lg flex items-center justify-center shrink-0 mt-1">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          </div>
          <div>
            <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
            <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center mt-10" data-animate>
      <a href="/contact" class="btn-primary">Décrivez-nous votre projet</a>
    </div>
  </Section>

  <!-- SECTION 4 — Méthode -->
  <Section title="Comment se déroule votre chantier peinture ?" subtitle="Chaque étape est pensée pour un résultat durable, sans mauvaise surprise." bg="light">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6" data-animate>
      {[
        { step: "01", title: "Visite & conseil couleur", desc: "On vient chez vous, on évalue l'état des supports et on vous propose des teintes adaptées à la luminosité de chaque pièce. Devis détaillé sous 48h." },
        { step: "02", title: "Protection & préparation", desc: "Bâchage intégral des sols et meubles. Rebouchage des trous et fissures, ponçage, lessivage des anciennes peintures, application de la sous-couche." },
        { step: "03", title: "Application", desc: "2 couches croisées minimum au rouleau ou au pistolet airless selon la surface. Temps de séchage de 6h respecté entre chaque passe." },
        { step: "04", title: "Retouches & nettoyage", desc: "Inspection de chaque surface en lumière rasante. Retouches si nécessaire, retrait des bâches, nettoyage complet du chantier." },
      ].map((item) => (
        <div class="text-center">
          <div class="w-12 h-12 bg-accent text-white rounded-xl flex items-center justify-center mx-auto mb-3 text-lg font-bold">
            {item.step}
          </div>
          <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
          <p class="text-sm text-gray-medium">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- SECTION 5 — Pourquoi nous choisir -->
  <Section title="Pourquoi choisir Team Renov pour votre peinture ?" bg="white">
    <div class="max-w-5xl mx-auto" data-animate>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {[
          { title: "Peintres expérimentés", desc: "Plus de 10 ans sur les chantiers. Nos artisans maîtrisent aussi bien la peinture classique que les effets décoratifs haut de gamme." },
          { title: "Peintures de marque", desc: "Tollens, Sikkens, Zolpan : on ne travaille qu'avec des peintures professionnelles à haut pouvoir couvrant. Les références figurent sur votre devis." },
          { title: "2 couches minimum", desc: "On ne négocie jamais sur le nombre de couches. Deux couches croisées, c'est le minimum pour un résultat uniforme et durable dans le temps." },
          { title: "Chantier protégé", desc: "Bâches sur tous les sols, scotch de masquage sur les plinthes et encadrements, meubles recouverts. On quitte votre logement plus propre qu'en arrivant." },
          { title: "Coordination intégrée", desc: "Besoin d'enduit, de placo ou de menuiserie avant la peinture ? On gère tout en interne. Un seul interlocuteur, un seul planning." },
          { title: "Devis au m² détaillé", desc: "Chaque poste est chiffré : préparation, sous-couche, finition, main-d'œuvre. Vous savez exactement ce que vous payez, ligne par ligne." },
        ].map((item) => (
          <div class="card">
            <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
            <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center">
        <p class="text-lg text-gray-dark font-medium mb-4">
          Prêt à redonner un coup de neuf à votre intérieur ?
        </p>
        <a href="/contact" class="btn-primary">Demander un devis gratuit</a>
      </div>
    </div>
  </Section>

  <!-- SECTION 6 — FAQ SEO -->
  <!-- FAQ schema à ajouter en JSON-LD -->
  <Section title="Questions fréquentes sur la peinture intérieure" bg="light">
    <div class="max-w-3xl mx-auto space-y-0" data-animate>
      {[
        {
          q: "Combien coûte la peinture d'un appartement ?",
          a: "Le tarif dépend de la surface, de l'état des murs et du type de peinture choisi. En moyenne, comptez entre 15 € et 35 € TTC/m² (fournitures et main-d'œuvre). Pour un T3 de 65 m², le budget total se situe entre 2 500 € et 5 000 €. On détaille tout dans le devis."
        },
        {
          q: "Combien de temps faut-il pour peindre un appartement ?",
          a: "Un studio se peint en 1 à 2 jours. Un T3 complet (murs + plafonds) demande 3 à 5 jours ouvrés, préparation incluse. On fixe les dates dès le devis et on s'y tient."
        },
        {
          q: "Faut-il vider les pièces avant les travaux ?",
          a: "Pas forcément. On déplace les meubles au centre de la pièce et on les bâche intégralement. Si une pièce est très encombrée, on vous demandera de dégager les objets fragiles uniquement."
        },
        {
          q: "Quelle peinture choisir : mate, satinée ou brillante ?",
          a: "Mate pour les plafonds et les pièces calmes (chambre, salon). Satinée pour les pièces humides (cuisine, salle de bain) et les pièces à fort passage — elle se nettoie facilement. Brillante uniquement pour les boiseries. On vous conseille sur place."
        },
        {
          q: "Les peintures utilisées sont-elles sans danger ?",
          a: "On propose des gammes à faible émission de COV (composés organiques volatils), classées A+. Elles sont sans odeur forte et adaptées aux chambres d'enfants et pièces de vie. La ventilation reste recommandée pendant 24h après application."
        },
      ].map((item) => (
        <details class="group border-b border-gray-200">
          <summary class="cursor-pointer flex items-center justify-between py-4 font-semibold text-primary hover:text-accent transition-colors">
            {item.q}
            <svg class="w-5 h-5 shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-gray-medium text-sm leading-relaxed pb-4">{item.a}</p>
        </details>
      ))}
    </div>
  </Section>

  <!-- SECTION 7 — Chiffres clés -->
  <Section title="Team Renov en chiffres" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-animate>
      {[
        { value: "10+", label: "ans d'expérience" },
        { value: "150+", label: "chantiers réalisés" },
        { value: "48h", label: "pour votre devis" },
        { value: "100%", label: "assuré décennale" },
      ].map((stat) => (
        <div>
          <div class="text-4xl font-extrabold text-accent mb-1">{stat.value}</div>
          <div class="text-sm text-gray-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </Section>
</ServicePageLayout>
