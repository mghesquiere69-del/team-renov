---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Murs & plafonds",
  "Boiseries & portes",
  "Finitions mates & satinées",
  "Peintures écologiques",
];

const relatedServices = [
  { title: "Enduit", href: "/services/enduit" },
  { title: "Placo & Rails", href: "/services/placo-rails" },
  { title: "Rénovation complète", href: "/services/renovation-complete" },
  { title: "Menuiserie", href: "/services/menuiserie" },
];
---

<ServicePageLayout
  title="Peinture intérieure"
  metaTitle="Peinture Intérieure – Team Renov | Murs, Plafonds & Boiseries"
  metaDescription="Peinture intérieure tous supports : murs, plafonds, boiseries. Finitions soignées, peintures de qualité. Devis gratuit en 48h."
  category="Travaux Intérieurs"
  categoryHref="/services#interieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <Section title="Une finition qui fait toute la différence" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10" data-animate>
      <div class="space-y-4">
        <p class="text-gray-medium leading-relaxed">
          La peinture est la touche finale qui transforme un espace. Nos peintres
          expérimentés interviennent sur tous types de supports — plâtre, bois, métal —
          avec des peintures de qualité professionnelle pour un rendu impeccable.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Nous vous accompagnons dans le choix des couleurs et des finitions (mate,
          satinée, velours) et proposons des gammes de peintures écologiques à faible
          émission de COV pour un intérieur sain et durable.
        </p>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm">
        Photo peinture intérieure
      </div>
    </div>
  </Section>

  <Section title="Nos prestations peinture" bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        { title: "Peinture murs", desc: "Application soignée sur murs neufs ou rénovés, avec préparation des supports incluse." },
        { title: "Peinture plafonds", desc: "Peinture de plafonds lisses ou texturés avec traitement des fissures existantes." },
        { title: "Boiseries & portes", desc: "Laquage et peinture de portes, plinthes, encadrements et menuiseries intérieures." },
        { title: "Effets décoratifs", desc: "Techniques spéciales : peinture à la chaux, enduit décoratif, stucco et badigeon." },
        { title: "Préparation", desc: "Ponçage, lessivage, enduit de rebouchage et sous-couche pour une adhérence optimale." },
        { title: "Protection", desc: "Bâchage complet de vos meubles et sols, respect de votre intérieur." },
      ].map((item) => (
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>
</ServicePageLayout>
