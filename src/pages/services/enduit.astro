---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Lissage & rebouchage",
  "Bandes à joints invisibles",
  "Devis gratuit sous 48h",
  "Surfaces prêtes à peindre",
];

const relatedServices = [
  { title: "Placo & Rails", href: "/services/placo-rails" },
  { title: "Peinture", href: "/services/peinture" },
  { title: "Carrelage", href: "/services/carrelage" },
  { title: "Rénovation complète", href: "/services/renovation-complete" },
  { title: "Clé en main", href: "/services/cle-en-main" },
];
---

<ServicePageLayout
  title="Enduit intérieur"
  metaTitle="Enduit Intérieur – Team Renov | Lissage & Finition | Île-de-France"
  metaDescription="Enduiseur en Île-de-France : rebouchage, lissage, bandes à joints, rattrapage de murs. Surfaces parfaitement lisses, prêtes à peindre. Devis gratuit 48h."
  category="Travaux Intérieurs"
  categoryHref="/services#interieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <!-- SECTION 1 — Accroche : Problème → Agitation → Solution -->
  <Section title="Vos murs sont bosselés, fissurés, irréguliers ? On les rend parfaits." bg="white">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center" data-animate>
      <div class="space-y-5">
        <p class="text-gray-medium leading-relaxed">
          Bosses autour des prises, bandes à joints visibles, anciennes fissures mal rebouchées…
          <strong class="text-gray-dark">Un mur mal préparé, c'est une peinture qui ne tient pas et un rendu médiocre</strong> —
          même avec la meilleure peinture du marché. L'enduit, c'est le travail invisible qui fait toute la différence entre un intérieur amateur et un résultat professionnel.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Chez <strong class="text-gray-dark">Team Renov</strong>, l'enduit n'est pas un simple coup de spatule.
          Nos enduiseurs appliquent méthodiquement chaque couche — rebouchage, lissage, finition — avec un <strong class="text-gray-dark">ponçage inter-couches au grain 120</strong> et un contrôle systématique en lumière rasante.
          Résultat : des surfaces parfaitement planes, sans aucune ondulation, prêtes à recevoir n'importe quelle finition.
        </p>
        <p class="text-gray-medium leading-relaxed">
          On intervient sur tous les supports : placo neuf, plâtre ancien, béton, parpaing enduit, murs anciens irréguliers.
          Que ce soit après une pose de cloisons ou pour remettre en état un appartement haussmannien, on s'adapte au support et à la finition visée.
        </p>
        <ul class="space-y-2 text-sm text-gray-medium">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Enduits Toupret, Semin, Placo — qualité professionnelle
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Contrôle en lumière rasante à chaque étape
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Aspiration fine après ponçage — chantier propre garanti
          </li>
        </ul>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm italic">
        Photo : enduiseur Team Renov appliquant un enduit de lissage à la spatule large sur un mur en placo, lumière rasante visible
      </div>
    </div>
  </Section>

  <!-- SECTION 2 — Prestations détaillées -->
  <Section title="Nos prestations enduit" subtitle="Du rebouchage grossier à la finition miroir, chaque étape est réalisée avec précision." bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        {
          title: "Enduit de rebouchage",
          desc: "Comblement des trous de chevilles, saignées électriques, fissures et éclats. On utilise du Toupret Reboucheur ou du Semin CE 78 selon la profondeur. Chaque rebouchage est poncé à plat avant la passe suivante.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1m0 0L3 12.75m3.32-2.68L12 3.75l2.25 2.25M17.58 8.83l5.1 5.1m0 0l-3.32 2.68m3.32-2.68L17.25 20.25l-2.25-2.25"/></svg>`
        },
        {
          title: "Enduit de lissage",
          desc: "Application d'une à deux passes d'enduit fin (Toupret TX 110 ou équivalent) à la lisseuse inox de 60 cm. On croise les passes pour éliminer les ondulations. Épaisseur contrôlée : 1 à 2 mm par passe maximum.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6z"/></svg>`
        },
        {
          title: "Bandes à joints",
          desc: "Traitement des joints de plaques de plâtre en 3 passes : calicot noyé dans l'enduit, première passe de remplissage, deuxième passe de lissage élargi. Résultat : raccords totalement invisibles, même en lumière rasante.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>`
        },
        {
          title: "Rattrapage de murs anciens",
          desc: "Murs en plâtre fissuré, ancienne toile de verre arrachée, crépi intérieur à supprimer ? On gratte, on purge les parties friables, on applique un primaire d'accrochage puis on reprend tout à l'enduit jusqu'à retrouver une surface plane.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75"/></svg>`
        },
        {
          title: "Ponçage & dépoussiérage",
          desc: "Ponçage mécanique au grain 120 entre chaque couche, puis grain 150 en finition. Aspiration directe à la girafe pour un chantier propre. Chaque surface est contrôlée en lumière rasante avant de passer à l'étape suivante.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>`
        },
        {
          title: "Enduit de dégrossissage",
          desc: "Pour les murs très irréguliers (parpaings, pierres, béton brut), on applique un enduit de dégrossissage en forte épaisseur (5 à 15 mm) avant le lissage. On utilise des guides et des règles pour assurer la planéité.",
          icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5M13.5 6.75H15m-1.5 3H15m-1.5 3H15"/></svg>`
        },
      ].map((item) => (
        <div class="card">
          <div class="w-10 h-10 bg-accent/10 text-accent rounded-lg flex items-center justify-center mb-3">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- SECTION 3 — Cas d'usage concrets -->
  <Section title="Vos projets enduit, nos solutions" bg="white">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8" data-animate>
      {[
        {
          title: "Finition après pose de placo",
          desc: "Vous venez de faire poser des cloisons en placo ? On prend le relais : bandes à joints en 3 passes, rebouchage des vis, enduit de lissage intégral. Vos murs sont prêts à peindre en quelques jours. On coordonne directement avec nos plaquistes.",
        },
        {
          title: "Remise en état d'un appartement ancien",
          desc: "Plâtre fissuré, crépi intérieur disgracieux, traces de papier peint arrachées… On reprend tout de zéro : grattage, primaire d'accrochage, enduit de rattrapage, puis lissage. Le résultat est un mur neuf, lisse et uniforme.",
        },
        {
          title: "Préparation avant peinture haut de gamme",
          desc: "Une peinture satinée ou un enduit décoratif (stucco, badigeon) exige un support impeccable. On réalise un lissage de qualité Q4 — le niveau le plus exigeant — avec plusieurs passes et un ponçage final au grain 150 pour un rendu miroir.",
        },
        {
          title: "Réparation après dégât des eaux ou travaux",
          desc: "Saignées d'électricien, trous de plombier, auréoles d'humidité traitées : on rebouche, on lisse et on raccorde l'enduit existant pour que les réparations soient totalement invisibles. Même teinte, même texture.",
        },
      ].map((item) => (
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-primary/10 text-primary rounded-lg flex items-center justify-center shrink-0 mt-1">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          </div>
          <div>
            <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
            <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center mt-10" data-animate>
      <a href="/contact" class="btn-primary">Décrivez-nous votre projet</a>
    </div>
  </Section>

  <!-- SECTION 4 — Méthode -->
  <Section title="Comment se déroule votre chantier enduit ?" subtitle="Un process rigoureux pour des surfaces parfaitement lisses, sans raccord visible." bg="light">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6" data-animate>
      {[
        { step: "01", title: "Diagnostic des supports", desc: "On examine chaque mur : type de support, état de surface, fissures actives ou non, humidité résiduelle. On définit le nombre de passes nécessaires et le type d'enduit adapté." },
        { step: "02", title: "Rebouchage & sous-couche", desc: "Comblement de tous les défauts (trous, saignées, fissures) avec un enduit de rebouchage. Séchage complet puis ponçage. Application d'un primaire d'accrochage si le support le nécessite." },
        { step: "03", title: "Lissage en passes croisées", desc: "Application d'une à deux passes d'enduit de lissage à la lisseuse inox. Chaque couche est poncée au grain 120 avant la suivante. Contrôle en lumière rasante à chaque étape." },
        { step: "04", title: "Ponçage final & réception", desc: "Ponçage de finition au grain 150, aspiration de la poussière, contrôle final en lumière rasante. Le mur est livré prêt à peindre ou à recevoir un revêtement décoratif." },
      ].map((item) => (
        <div class="text-center">
          <div class="w-12 h-12 bg-accent text-white rounded-xl flex items-center justify-center mx-auto mb-3 text-lg font-bold">
            {item.step}
          </div>
          <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
          <p class="text-sm text-gray-medium">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- SECTION 5 — Pourquoi nous choisir -->
  <Section title="Pourquoi choisir Team Renov pour vos enduits ?" bg="white">
    <div class="max-w-5xl mx-auto" data-animate>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {[
          { title: "Enduiseurs spécialisés", desc: "Plus de 10 ans d'expérience en lissage et rattrapage de surfaces. Nos artisans maîtrisent aussi bien le placo neuf que le plâtre ancien, avec un souci constant de la planéité." },
          { title: "Enduits de marque", desc: "Toupret, Semin, Placo : on ne travaille qu'avec des enduits professionnels à prise contrôlée. Les références figurent sur votre devis — pas de produits de grande surface." },
          { title: "Contrôle lumière rasante", desc: "À chaque étape, on vérifie la surface en lumière rasante (lampe halogène ou LED à ras du mur). C'est le test le plus exigeant : il révèle la moindre ondulation." },
          { title: "Ponçage mécanique", desc: "Girafe de ponçage avec aspiration intégrée. Résultat : un ponçage uniforme, rapide, et un chantier qui reste propre. Pas de nuage de poussière dans votre intérieur." },
          { title: "Coordination intégrée", desc: "Placo en amont, peinture en aval ? On gère toute la chaîne en interne. Un seul interlocuteur, un seul planning. Pas de temps mort entre les corps de métier." },
          { title: "Devis au m² détaillé", desc: "Chaque poste est chiffré séparément : rebouchage, lissage, bandes à joints, ponçage. Vous savez exactement ce que vous payez, sans mauvaise surprise à la fin." },
        ].map((item) => (
          <div class="card">
            <h3 class="text-base font-semibold text-primary mb-1">{item.title}</h3>
            <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center">
        <p class="text-lg text-gray-dark font-medium mb-4">
          Prêt à retrouver des murs parfaitement lisses ?
        </p>
        <a href="/contact" class="btn-primary">Demander un devis gratuit</a>
      </div>
    </div>
  </Section>

  <!-- SECTION 6 — FAQ SEO -->
  <Section title="Questions fréquentes sur l'enduit intérieur" bg="light">
    <div class="max-w-3xl mx-auto space-y-0" data-animate>
      {[
        {
          q: "Combien coûte un enduit de lissage au m² ?",
          a: "En moyenne, comptez entre 12 € et 25 € TTC/m² pour un enduit de lissage complet (rebouchage + lissage + ponçage), fournitures et main-d'œuvre incluses. Le prix varie selon l'état initial du support : un mur en placo neuf coûte moins cher qu'un mur ancien très irrégulier."
        },
        {
          q: "Quelle est la différence entre enduit de rebouchage et enduit de lissage ?",
          a: "L'enduit de rebouchage comble les gros défauts (trous, fissures, saignées) en épaisseur (jusqu'à 3 cm). L'enduit de lissage s'applique en couche fine (1-2 mm) sur toute la surface pour obtenir un mur parfaitement plan. Les deux sont complémentaires : on rebouche d'abord, on lisse ensuite."
        },
        {
          q: "Combien de passes d'enduit faut-il ?",
          a: "Sur du placo neuf avec bandes à joints, 2 passes de lissage suffisent généralement (qualité Q3). Pour une finition haut de gamme (peinture satinée, enduit décoratif), on passe en Q4 avec 3 passes minimum. Sur un mur ancien très abîmé, il peut falloir 4 à 5 passes au total."
        },
        {
          q: "Combien de temps faut-il pour enduire un appartement ?",
          a: "Pour un T3 de 65 m², comptez 4 à 7 jours ouvrés en qualité Q3 (temps de séchage inclus entre chaque couche). En Q4, ajoutez 2 à 3 jours supplémentaires. Le ponçage final prend une demi-journée. On fixe les délais précis dès le devis."
        },
        {
          q: "L'enduit génère-t-il beaucoup de poussière ?",
          a: "Le ponçage génère de la poussière fine, mais on utilise des girafes de ponçage avec aspiration intégrée qui captent 90% des particules. On bâche et on aspire soigneusement en fin de journée. Votre logement reste habitable pendant les travaux."
        },
      ].map((item) => (
        <details class="group border-b border-gray-200">
          <summary class="cursor-pointer flex items-center justify-between py-4 font-semibold text-primary hover:text-accent transition-colors">
            {item.q}
            <svg class="w-5 h-5 shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <p class="text-gray-medium text-sm leading-relaxed pb-4">{item.a}</p>
        </details>
      ))}
    </div>
  </Section>

  <!-- SECTION 7 — Chiffres clés -->
  <Section title="Team Renov en chiffres" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center" data-animate>
      {[
        { value: "10+", label: "ans d'expérience" },
        { value: "150+", label: "chantiers réalisés" },
        { value: "48h", label: "pour votre devis" },
        { value: "100%", label: "assuré décennale" },
      ].map((stat) => (
        <div>
          <div class="text-4xl font-extrabold text-accent mb-1">{stat.value}</div>
          <div class="text-sm text-gray-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </Section>
</ServicePageLayout>
