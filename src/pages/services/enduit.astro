---
import ServicePageLayout from "../../layouts/ServicePageLayout.astro";
import Section from "../../components/Section.astro";

const highlights = [
  "Enduit de lissage",
  "Enduit de finition",
  "Rattrapage de supports",
  "Surfaces prêtes à peindre",
];

const relatedServices = [
  { title: "Placo & Rails", href: "/services/placo-rails" },
  { title: "Peinture", href: "/services/peinture" },
  { title: "Carrelage", href: "/services/carrelage" },
  { title: "Rénovation complète", href: "/services/renovation-complete" },
];
---

<ServicePageLayout
  title="Enduit intérieur"
  metaTitle="Enduit Intérieur – Team Renov | Lissage & Finition de Murs"
  metaDescription="Application d'enduits de lissage et de finition pour des murs parfaitement lisses. Artisans qualifiés, devis gratuit en 48h."
  category="Travaux Intérieurs"
  categoryHref="/services#interieurs"
  icon={`<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`}
  highlights={highlights}
  relatedServices={relatedServices}
>
  <Section title="Des murs impeccables" bg="white">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10" data-animate>
      <div class="space-y-4">
        <p class="text-gray-medium leading-relaxed">
          L'enduit est une étape essentielle de toute rénovation intérieure. Il permet
          de rattraper les imperfections des murs, de lisser les surfaces après la pose
          de placo et de préparer vos supports pour une finition peinture parfaite.
        </p>
        <p class="text-gray-medium leading-relaxed">
          Nos enduiseurs maîtrisent toutes les techniques : enduit de rebouchage pour
          combler les trous et fissures, enduit de lissage pour obtenir une surface
          plane, et enduit de finition pour un rendu lisse et uniforme.
        </p>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm">
        Photo application enduit
      </div>
    </div>
  </Section>

  <Section title="Nos prestations enduit" bg="light">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto" data-animate>
      {[
        { title: "Enduit de rebouchage", desc: "Comblement des trous, fissures et saignées pour un support homogène." },
        { title: "Enduit de lissage", desc: "Application d'une couche fine pour des murs parfaitement plans et réguliers." },
        { title: "Enduit de finition", desc: "Dernière passe pour un rendu lisse, prêt à recevoir peinture ou papier peint." },
        { title: "Rattrapage de murs", desc: "Traitement des murs anciens, irréguliers ou endommagés avant finition." },
        { title: "Bandes à joints", desc: "Traitement des joints de plaques de plâtre pour des raccords invisibles." },
        { title: "Ponçage & préparation", desc: "Ponçage soigné et dépoussiérage pour une surface impeccable." },
      ].map((item) => (
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
          <p class="text-sm text-gray-medium leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </Section>
</ServicePageLayout>
