const exteriorServices = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/></svg>`,
    title: "Maçonnerie",
    description: "Construction, réparation et renforcement de structures en maçonnerie.",
    href: "/services/maconnerie",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6z"/></svg>`,
    title: "Carrelage extérieur",
    description: "Pose de carrelage, dalles et pavés pour terrasses, allées et abords de piscine.",
    href: "/services/carrelage#exterieur",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Drain français",
    description: "Installation de drains français pour protéger vos fondations contre l'humidité.",
    href: "/services/drain-francais",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128z"/></svg>`,
    title: "Enduit projeté",
    description: "Application d'enduits projetés pour façades modernes et protégées durablement.",
    href: "/services/enduit-projete",
  },
];
---

<BaseLayout
  title="Nos Services – Team Renov | Travaux de Rénovation Intérieure & Extérieure"
  description="Découvrez l'ensemble de nos services : travaux intérieurs, extérieurs, menuiserie et projets clés en main. Devis gratuit en 48h."
>
  <!-- Hero banner -->
  <section class="bg-primary py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Nos Services</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Du sol au plafond, de l'intérieur à l'extérieur, nous intervenons sur
        l'ensemble de vos travaux de rénovation et de construction.
      </p>
    </div>
  </section>

  <!-- Interior -->
  <Section
    title="Travaux Intérieurs"
    subtitle="Tous les corps de métier pour rénover vos espaces intérieurs avec soin et précision."
    bg="white"
    id="interieurs"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" data-animate>
      {interiorServices.map((s) => <ServiceCard {...s} />)}
    </div>
  </Section>

  <!-- Exterior -->
  <Section
    title="Travaux Extérieurs"
    subtitle="Valorisez et protégez vos extérieurs avec des solutions durables et esthétiques."
    bg="light"
    id="exterieurs"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
      {exteriorServices.map((s) => <ServiceCard {...s} />)}
    </div>
  </Section>

  <!-- Menuiserie -->
  <Section
    title="Menuiserie"
    subtitle="Pose et rénovation de menuiseries intérieures et extérieures, fabriquées sur mesure."
    bg="white"
    id="menuiserie"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center" data-animate>
      <div class="space-y-4">
        <p class="text-gray-medium leading-relaxed">
          Nous réalisons la pose et la dépose de toutes vos menuiseries : portes,
          fenêtres, volets, portails, placards et dressings. Chaque réalisation est
          adaptée à vos besoins en termes d'isolation, de sécurité et d'esthétique.
        </p>
        <ul class="space-y-3">
          {["Portes intérieures & extérieures", "Fenêtres & baies vitrées", "Volets & persiennes", "Placards & dressings sur mesure", "Escaliers & garde-corps"].map((item) => (
            <li class="flex items-center gap-3 text-sm text-gray-dark">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="bg-gray-200 rounded-2xl aspect-[4/3] flex items-center justify-center text-gray-400 text-sm">
        Photo menuiserie
      </div>
    </div>
    <div class="text-center mt-8">
      <a href="/services/menuiserie" class="btn-primary">En savoir plus</a>
    </div>
  </Section>

  <!-- Clé en main -->
  <Section
    title="Projets Clés en Main"
    subtitle="Un seul interlocuteur du début à la fin pour une rénovation sans stress."
    bg="light"
    id="cle-en-main"
  >
    <div class="max-w-4xl mx-auto" data-animate>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {[
          { step: "01", title: "Étude", desc: "Visite technique, prise de cotes et compréhension de vos besoins." },
          { step: "02", title: "Devis", desc: "Proposition détaillée et transparente sous 48h avec planning prévisionnel." },
          { step: "03", title: "Travaux", desc: "Coordination de tous les corps de métier avec suivi quotidien." },
          { step: "04", title: "Livraison", desc: "Réception des travaux, contrôle qualité et garantie décennale." },
        ].map((item) => (
          <div class="text-center">
            <div class="w-14 h-14 bg-accent text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-xl font-bold">
              {item.step}
            </div>
            <h3 class="text-lg font-semibold text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-gray-medium">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/services/cle-en-main" class="btn-primary">En savoir plus</a>
      </div>
    </div>
  </Section>
</BaseLayout>
