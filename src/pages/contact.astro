---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";

const projectTypes = [
  "Rénovation cuisine",
  "Rénovation salle de bain",
  "Rénovation complète appartement",
  "Rénovation complète maison",
  "Travaux de peinture",
  "Carrelage / Faïence",
  "Plomberie",
  "Électricité",
  "Maçonnerie extérieure",
  "Menuiserie",
  "Autre",
];

const sentStatus = Astro.url.searchParams.get("sent");
---

<BaseLayout
  title="Contact & Devis – Team Renov | Estimation Gratuite en Ligne"
  description="Demandez votre devis gratuit en 48h. Estimation en ligne, formulaire de contact et simulation de budget pour vos travaux de rénovation."
>
  <!-- Hero -->
  <section class="bg-primary py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Contactez-nous</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Demandez votre devis gratuit ou estimez le budget de votre projet en quelques clics.
        Nous vous répondons sous 48h.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Contact form -->
      <div class="lg:col-span-2" data-animate>
        <h2 class="text-2xl font-bold text-primary mb-6">Demande de devis</h2>
        {sentStatus === "1" && (
          <div id="form-success" class="mb-6 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
            <p class="font-semibold">Demande envoyee avec succes.</p>
            <p>Votre email a bien ete transmis. Nous revenons vers vous rapidement.</p>
          </div>
        )}
        {sentStatus === "0" && (
          <p class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
            L'envoi a echoue. Merci de reessayer dans quelques instants.
          </p>
        )}

        <form id="quote-form" class="space-y-6" action="https://formsubmit.co/travaux.jd1@gmail.com" method="POST">
          <input type="hidden" name="_subject" value="Nouvelle demande de devis - Team Renov" />
          <input type="hidden" id="form-next-url" name="_next" value="/contact?sent=1#form-success" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="firstname" class="block text-sm font-medium text-gray-dark mb-2">Prénom *</label>
              <input
                type="text"
                id="firstname"
                name="firstname"
                required
                autocomplete="given-name"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="Jean"
              />
            </div>
            <div>
              <label for="lastname" class="block text-sm font-medium text-gray-dark mb-2">Nom *</label>
              <input
                type="text"
                id="lastname"
                name="lastname"
                required
                autocomplete="family-name"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="Dupont"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-dark mb-2">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="jean.dupont@email.com"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-dark mb-2">Téléphone *</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                autocomplete="tel"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="06 12 34 56 78"
              />
            </div>
          </div>

          <div>
            <label for="project-type" class="block text-sm font-medium text-gray-dark mb-2">Type de projet *</label>
            <select
              id="project-type"
              name="project-type"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors bg-white"
            >
              <option value="">Sélectionnez un type de travaux</option>
              {projectTypes.map((type) => (
                <option value={type}>{type}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-dark mb-2">Description du projet *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors resize-y"
              placeholder="Décrivez votre projet : type de travaux, surface, contraintes particulières..."
            ></textarea>
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <button type="submit" class="btn-primary w-full sm:w-auto text-base">
              Envoyer ma demande de devis
            </button>
            <button type="button" id="whatsapp-btn" class="btn-secondary !border-primary !text-primary hover:!bg-primary hover:!text-white w-full sm:w-auto text-base">
              Envoyer aussi par WhatsApp
            </button>
          </div>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="space-y-8" data-animate>
        <!-- Contact info -->
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-4">Informations de contact</h3>
          <ul class="space-y-4 text-sm text-gray-dark">
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              <a href="tel:+33621530453" class="hover:text-primary transition-colors">06 21 53 04 53</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              <a href="mailto:travaux.jd1@gmail.com" class="hover:text-primary transition-colors">travaux.jd1@gmail.com</a>
            </li>
          </ul>
        </div>

        <!-- Hours -->
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-4">Horaires</h3>
          <ul class="space-y-2 text-sm">
            <li class="flex justify-between"><span class="text-gray-medium">Lun – Ven</span><span class="font-medium text-gray-dark">8h – 18h</span></li>
            <li class="flex justify-between"><span class="text-gray-medium">Samedi</span><span class="font-medium text-gray-dark">9h – 13h</span></li>
            <li class="flex justify-between"><span class="text-gray-medium">Dimanche</span><span class="font-medium text-gray-dark">Fermé</span></li>
          </ul>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const nextUrlInput = document.getElementById("form-next-url") as HTMLInputElement | null;
  if (nextUrlInput) {
    nextUrlInput.value = `${window.location.origin}/contact?sent=1#form-success`;
  }

  const quoteForm = document.getElementById("quote-form") as HTMLFormElement | null;
  const whatsappBtn = document.getElementById("whatsapp-btn") as HTMLButtonElement | null;

  if (quoteForm && whatsappBtn) {
    whatsappBtn.addEventListener("click", () => {
      if (!quoteForm.reportValidity()) {
        return;
      }

      const firstname = (document.getElementById("firstname") as HTMLInputElement).value.trim();
      const lastname = (document.getElementById("lastname") as HTMLInputElement).value.trim();
      const email = (document.getElementById("email") as HTMLInputElement).value.trim();
      const phone = (document.getElementById("phone") as HTMLInputElement).value.trim();
      const projectType = (document.getElementById("project-type") as HTMLSelectElement).value.trim();
      const message = (document.getElementById("message") as HTMLTextAreaElement).value.trim();

      const whatsappText = [
        "Bonjour, je souhaite demander un devis.",
        "",
        `Prenom: ${firstname}`,
        `Nom: ${lastname}`,
        `Email: ${email}`,
        `Telephone: ${phone}`,
        `Type de projet: ${projectType}`,
        "",
        "Description:",
        message,
      ].join("\n");

      const whatsappUrl = `https://wa.me/33621530453?text=${encodeURIComponent(whatsappText)}`;
      window.open(whatsappUrl, "_blank", "noopener,noreferrer");
    });
  }

</script>
