---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";

const projectTypes = [
  "Rénovation cuisine",
  "Rénovation salle de bain",
  "Rénovation complète appartement",
  "Rénovation complète maison",
  "Travaux de peinture",
  "Carrelage / Faïence",
  "Plomberie",
  "Électricité",
  "Maçonnerie extérieure",
  "Menuiserie",
  "Autre",
];
---

<BaseLayout
  title="Contact & Devis – Team Renov | Estimation Gratuite en Ligne"
  description="Demandez votre devis gratuit en 48h. Estimation en ligne, formulaire de contact et simulation de budget pour vos travaux de rénovation."
>
  <!-- Hero -->
  <section class="bg-primary py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Contactez-nous</h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto">
        Demandez votre devis gratuit ou estimez le budget de votre projet en quelques clics.
        Nous vous répondons sous 48h.
      </p>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

      <!-- Contact form -->
      <div class="lg:col-span-2" data-animate>
        <h2 class="text-2xl font-bold text-primary mb-6">Demande de devis</h2>
        <form class="space-y-6" action="#" method="POST">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="firstname" class="block text-sm font-medium text-gray-dark mb-2">Prénom *</label>
              <input
                type="text"
                id="firstname"
                name="firstname"
                required
                autocomplete="given-name"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="Jean"
              />
            </div>
            <div>
              <label for="lastname" class="block text-sm font-medium text-gray-dark mb-2">Nom *</label>
              <input
                type="text"
                id="lastname"
                name="lastname"
                required
                autocomplete="family-name"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="Dupont"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-dark mb-2">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="jean.dupont@email.com"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-dark mb-2">Téléphone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors"
                placeholder="06 12 34 56 78"
              />
            </div>
          </div>

          <div>
            <label for="project-type" class="block text-sm font-medium text-gray-dark mb-2">Type de projet *</label>
            <select
              id="project-type"
              name="project-type"
              required
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors bg-white"
            >
              <option value="">Sélectionnez un type de travaux</option>
              {projectTypes.map((type) => (
                <option value={type}>{type}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-dark mb-2">Description du projet *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-colors resize-y"
              placeholder="Décrivez votre projet : type de travaux, surface, contraintes particulières..."
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full sm:w-auto text-base">
            Envoyer ma demande de devis
          </button>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="space-y-8" data-animate>
        <!-- Contact info -->
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-4">Informations de contact</h3>
          <ul class="space-y-4 text-sm text-gray-dark">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              <span>12 Rue de la Rénovation<br/>75000 Paris, France</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              <a href="tel:+33123456789" class="hover:text-primary transition-colors">01 23 45 67 89</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              <a href="mailto:contact@team-renov.fr" class="hover:text-primary transition-colors">contact@team-renov.fr</a>
            </li>
          </ul>
        </div>

        <!-- Hours -->
        <div class="card">
          <h3 class="text-lg font-semibold text-primary mb-4">Horaires</h3>
          <ul class="space-y-2 text-sm">
            <li class="flex justify-between"><span class="text-gray-medium">Lun – Ven</span><span class="font-medium text-gray-dark">8h – 18h</span></li>
            <li class="flex justify-between"><span class="text-gray-medium">Samedi</span><span class="font-medium text-gray-dark">9h – 13h</span></li>
            <li class="flex justify-between"><span class="text-gray-medium">Dimanche</span><span class="font-medium text-gray-dark">Fermé</span></li>
          </ul>
        </div>

        <!-- Quick estimation -->
        <div class="card border-2 border-accent">
          <h3 class="text-lg font-semibold text-primary mb-2">Estimation rapide</h3>
          <p class="text-sm text-gray-medium mb-4">Obtenez une première estimation de budget pour votre projet.</p>
          <div class="space-y-4">
            <div>
              <label for="est-surface" class="block text-xs font-medium text-gray-dark mb-1">Surface (m²)</label>
              <input
                type="number"
                id="est-surface"
                min="1"
                placeholder="ex: 25"
                class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-colors text-sm"
              />
            </div>
            <div>
              <label for="est-type" class="block text-xs font-medium text-gray-dark mb-1">Type de travaux</label>
              <select
                id="est-type"
                class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:border-accent focus:ring-2 focus:ring-accent/20 outline-none transition-colors bg-white text-sm"
              >
                <option value="">Sélectionner</option>
                <option value="peinture">Peinture</option>
                <option value="carrelage">Carrelage</option>
                <option value="sdb">Salle de bain</option>
                <option value="cuisine">Cuisine</option>
                <option value="complet">Rénovation complète</option>
              </select>
            </div>
            <button
              type="button"
              id="estimate-btn"
              class="w-full px-4 py-2 bg-accent text-white font-semibold rounded-lg hover:bg-accent-dark transition-colors text-sm"
            >
              Calculer l'estimation
            </button>
            <div id="estimate-result" class="hidden text-center p-3 bg-accent/10 rounded-lg">
              <p class="text-xs text-gray-medium">Estimation indicative</p>
              <p class="text-2xl font-bold text-primary" id="estimate-value"></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById("estimate-btn")!;
  const result = document.getElementById("estimate-result")!;
  const value = document.getElementById("estimate-value")!;

  const pricePerM2: Record<string, [number, number]> = {
    peinture: [25, 45],
    carrelage: [50, 90],
    sdb: [800, 1500],
    cuisine: [500, 1200],
    complet: [700, 1400],
  };

  btn.addEventListener("click", () => {
    const surface = parseFloat(
      (document.getElementById("est-surface") as HTMLInputElement).value
    );
    const type = (document.getElementById("est-type") as HTMLSelectElement).value;

    if (!surface || !type || !pricePerM2[type]) {
      result.classList.add("hidden");
      return;
    }

    const [min, max] = pricePerM2[type];
    const low = Math.round(surface * min);
    const high = Math.round(surface * max);

    value.textContent = `${low.toLocaleString("fr-FR")} € – ${high.toLocaleString("fr-FR")} €`;
    result.classList.remove("hidden");
  });
</script>
