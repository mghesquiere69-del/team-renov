---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import ServiceCard from "../components/ServiceCard.astro";
import StatItem from "../components/StatItem.astro";
import TestimonialCard from "../components/TestimonialCard.astro";

const highlights = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008H15.75v-.008zm0 2.25h.008v.008H15.75V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z"/></svg>`,
    title: "Estimation en ligne unique",
    description: "Obtenez une première estimation de votre projet directement en ligne, sans engagement.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Devis en 48h",
    description: "Recevez un devis détaillé et transparent sous 48 heures après votre demande.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    title: "Suivi quotidien",
    description: "Restez informé chaque jour de l'avancement de votre chantier via un lien direct avec nos équipes.",
  },
];

const services = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
    title: "Travaux Intérieurs",
    description: "Placo, électricité, carrelage, plomberie, peinture et rénovation complète de vos pièces.",
    href: "/services#interieurs",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>`,
    title: "Travaux Extérieurs",
    description: "Maçonnerie, carrelage extérieur, drain français et enduit projeté pour sublimer vos extérieurs.",
    href: "/services#exterieurs",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.385-5.384a1.687 1.687 0 010-2.386l6.17-6.17a1.687 1.687 0 012.387 0l5.384 5.384M3.75 21h16.5M6.75 18.75v-3m9-1.5v4.5"/></svg>`,
    title: "Menuiserie",
    description: "Pose et rénovation de menuiseries intérieures et extérieures sur mesure.",
    href: "/services#menuiserie",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>`,
    title: "Projets Clés en Main",
    description: "Accompagnement complet du début à la fin : conception, travaux et finitions.",
    href: "/services#cle-en-main",
  },
];

const testimonials = [
  {
    quote: "Équipe très professionnelle et à l'écoute. Le suivi quotidien par photos et messages nous a vraiment rassurés. Résultat impeccable pour notre cuisine.",
    author: "Marie Dubois",
    location: "Paris 15e",
    rating: 5,
  },
  {
    quote: "Devis reçu en 24h, chantier commencé dans les temps et terminé avec une finition parfaite. Je recommande les yeux fermés.",
    author: "Thomas Martin",
    location: "Boulogne-Billancourt",
    rating: 5,
  },
  {
    quote: "Rénovation complète de notre salle de bain. Le rendu est magnifique et le prix très raisonnable. Professionnalisme exemplaire.",
    author: "Sophie Laurent",
    location: "Vincennes",
    rating: 5,
  },
];

const stats = [
  { icon: `&#127968;`, value: "500+", label: "Projets réalisés" },
  { icon: `&#128522;`, value: "98%", label: "Clients satisfaits" },
  { icon: `&#128197;`, value: "10+", label: "Années d'expérience" },
  { icon: `&#128119;`, value: "25+", label: "Artisans qualifiés" },
];
---

<BaseLayout title="Team Renov – Rénovation & Construction | Devis Gratuit en 48h">
  <!-- HERO -->
  <section class="relative bg-primary min-h-[85vh] flex items-center overflow-hidden">
    <!-- Background pattern -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style={`background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E")`}></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full mb-6 animate-fade-in">
          <span class="w-2 h-2 bg-accent rounded-full"></span>
          <span class="text-sm text-white/90 font-medium">Certifié RGE · Assurance décennale</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 animate-slide-up">
          Votre projet de rénovation
          <span class="text-accent block mt-2">entre de bonnes mains.</span>
        </h1>

        <p class="text-lg sm:text-xl text-white/80 mb-10 max-w-xl leading-relaxed animate-slide-up">
          De l'estimation à la livraison, nous transformons vos espaces avec
          discipline et savoir-faire. Devis gratuit en 48h.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-slide-up">
          <a href="/contact" class="btn-primary text-base px-10 py-4">
            Demander un devis gratuit
          </a>
          <a href="/services" class="btn-secondary text-base px-10 py-4">
            Découvrir nos services
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
        <path d="M0 60h1440V30S1080 0 720 0 0 30 0 30v30z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- HIGHLIGHTS (3 pillars) -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 -mt-8 relative z-10">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {highlights.map((item) => (
          <div class="card flex flex-col items-center text-center border border-gray-100" data-animate>
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-4 text-primary">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="text-lg font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-sm text-gray-medium leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <Section
    title="Nos Services"
    subtitle="Des solutions complètes pour tous vos projets de rénovation, du sol au plafond."
    bg="light"
  >
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" data-animate>
      {services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/services" class="btn-primary">Voir tous nos services</a>
    </div>
  </Section>

  <!-- STATS -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <StatItem {...stat} />
        ))}
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <Section
    title="Pourquoi Team Renov ?"
    subtitle="Une approche unique inspirée des valeurs du Kyokushin : discipline, rigueur et engagement."
    bg="white"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center" data-animate>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-primary mb-1">Transparence totale</h3>
            <p class="text-sm text-gray-medium">Devis détaillés, pas de surprises. Suivi photo quotidien de votre chantier.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-primary mb-1">Qualité artisanale</h3>
            <p class="text-sm text-gray-medium">Artisans qualifiés et matériaux premium pour un résultat durable et soigné.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-primary mb-1">Respect des délais</h3>
            <p class="text-sm text-gray-medium">Planning rigoureux et communication quotidienne pour tenir nos engagements.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-primary mb-1">Garanties solides</h3>
            <p class="text-sm text-gray-medium">Certification RGE et assurance décennale pour votre tranquillité d'esprit.</p>
          </div>
        </div>
      </div>
      <div class="bg-primary/5 rounded-2xl p-8 text-center">
        <div class="text-6xl mb-4" aria-hidden="true">🏗️</div>
        <h3 class="text-2xl font-bold text-primary mb-4">Prêt à démarrer ?</h3>
        <p class="text-gray-medium mb-6">Obtenez votre estimation en quelques clics et recevez un devis détaillé sous 48h.</p>
        <a href="/contact" class="btn-primary">Estimer mon projet</a>
      </div>
    </div>
  </Section>

  <!-- TESTIMONIALS -->
  <Section
    title="Ce que disent nos clients"
    subtitle="La satisfaction de nos clients est notre meilleure carte de visite."
    bg="light"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-animate>
      {testimonials.map((t) => (
        <TestimonialCard {...t} />
      ))}
    </div>
  </Section>

  <!-- GALLERY PREVIEW -->
  <Section
    title="Nos Réalisations"
    subtitle="Découvrez quelques-uns de nos projets récents en images."
    bg="white"
    id="realisations"
  >
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4" data-animate>
      {[
        "Rénovation cuisine",
        "Salle de bain moderne",
        "Carrelage extérieur",
        "Enduit projeté",
        "Maçonnerie",
        "Peinture intérieure",
      ].map((label) => (
        <div class="relative aspect-[4/3] bg-gray-200 rounded-xl overflow-hidden group cursor-pointer">
          <div class="absolute inset-0 bg-primary/20 group-hover:bg-primary/40 transition-colors"></div>
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-4">
            <p class="text-white text-sm font-medium">{label}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/realisations" class="btn-primary">Voir toutes nos réalisations</a>
    </div>
  </Section>

  <!-- CTA -->
  <section class="bg-primary py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center" data-animate>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Lancez votre projet dès aujourd'hui
      </h2>
      <p class="text-lg text-white/80 mb-8 leading-relaxed">
        Obtenez une estimation gratuite en ligne ou appelez-nous directement.
        Notre équipe vous répond sous 48h avec un devis détaillé.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn-primary text-base px-10 py-4">
          Demander un devis gratuit
        </a>
        <a href="tel:+33123456789" class="btn-secondary text-base px-10 py-4">
          01 23 45 67 89
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
