---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
}

const { icon, title, description, href } = Astro.props;
const Tag = href ? "a" : "div";
---

<Tag href={href} class="card group block text-center">
  <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mx-auto mb-4 group-hover:bg-primary group-hover:text-white transition-all duration-300">
    <span class="text-2xl text-primary group-hover:text-white transition-colors" set:html={icon} />
  </div>
  <h3 class="text-lg font-semibold text-primary mb-2">{title}</h3>
  <p class="text-sm text-gray-medium leading-relaxed">{description}</p>
  {href && (
    <span class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-accent group-hover:gap-2 transition-all">
      En savoir plus
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    </span>
  )}
</Tag>
