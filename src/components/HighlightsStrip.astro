---
const highlights = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    title: "Devis en 48h",
    description: "Recevez un devis détaillé et transparent sous 48 heures après votre demande. Sans engagement.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
    title: "Suivi quotidien",
    description: "Restez informé chaque jour de l'avancement de votre chantier via un lien direct avec nos équipes.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Assurance décennale",
    description: "Vos travaux sont couverts pendant 10 ans. Solidité de l'ouvrage et conformité garanties.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Certification RGE",
    description: "Éligible aux aides MaPrimeRénov', éco-PTZ et certificats d'économie d'énergie.",
  },
];
---

<!-- Desktop: 4 cartes sur une ligne -->
<section class="hidden lg:block py-16 px-4 lg:px-8 -mt-8 relative z-10">
  <div class="max-w-7xl mx-auto" style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;">
    {highlights.map((item) => (
      <div class="card flex flex-col items-center text-center border border-gray-100" data-animate>
        <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-4 text-primary">
          <Fragment set:html={item.icon} />
        </div>
        <h3 class="text-lg font-bold text-primary mb-2">{item.title}</h3>
        <p class="text-sm text-gray-medium leading-relaxed">{item.description}</p>
      </div>
    ))}
  </div>
</section>
<!-- Mobile/Tablette: strip compact -->
<section class="lg:hidden bg-gray-light py-6 px-4 border-t border-gray-200">
  <div class="max-w-xl mx-auto flex flex-col gap-4">
    {highlights.map((item) => (
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center shrink-0 text-accent">
          <Fragment set:html={item.icon} />
        </div>
        <div>
          <h3 class="text-sm font-semibold text-primary">{item.title}</h3>
          <p class="text-xs text-gray-medium leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
